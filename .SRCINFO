pkgbase = granolie
	pkgdesc = Linux-first local AI meeting notes app with transcription and structured summaries
	pkgver = 0.1.0
pkgrel = 32
	url = https://github.com/mezzenger/Granolie
	arch = x86_64
	license = custom:UNLICENSED
	depends = at-spi2-core
	depends = gtk3
	depends = libnotify
	depends = libsecret
	depends = libxss
	depends = libxtst
	depends = nss
	depends = xdg-utils
	optdepends = libappindicator-gtk3: tray integration support
	optdepends = python: local faster-whisper transcription runtime and LibreOffice Writer integration
	optdepends = uv: on-demand bootstrap for the local faster-whisper helper
	options = !strip
	options = !debug

pkgname = granolie
